        <!-- ============================================================ -->
        <!-- CONTENT LAYER                                                -->
        <!-- ============================================================ -->

        <!-- Dead centre: (1100, 750) for 2200x1500 -->
        <!-- Horizontal centre-line: x=1100 -->
        <!-- Vertical centre-line: y=750 -->
        <!-- All content built symmetrically from these axes -->

        <!-- Layout plan:
             Zone A (y=60-310): APPLICATION LAYER — 4 component boxes
               Source Controller (Rust), Slint UI (Rust), VU Meter (Rust), Metadata APIs
             Zone B (y=380-680): SOFTWARE LAYER — 3 sources + PipeWire + Pi OS base
               MPD, tidal-connect, Plexamp → PipeWire → Monitor tap
             Zone C (y=750-1100): HARDWARE LAYER — Pi 4B central, peripherals, NAD chain
               GPIO Buttons, Touch Display, Pi 4B, Digi2 Pro, TOSLINK, NAD, Speakers
             Zone D (y=1130-1260): LEGEND
             Title block: bottom-right (1680, 1300)

             Content width: ~1900px, centred at x=1100
             Left margin: 1100 - 950 = 150 from centre = x=150
             Right margin: 1100 + 950 = 2050

             Audio flow arrows: top-to-bottom (sources→PipeWire→Digi→NAD)
             Control flow arrows: left margin (GPIO→Controller→sources)
             Display flow arrows: right margin (Metadata→UI→Display)
             Monitor tap: right side (PipeWire→VU→Display)
        -->

