        <!-- ============================================================ -->

        <!-- Dead centre: (800, 550) for 1600x1100 -->
        <!-- Scale: 3px per mm (case 435x70mm = 1305x210px) -->
        <!-- Case origin: (800 - 1305/2, 420 - 210/2) = (147.5, 315) -->
        <!-- Case end: (147.5 + 1305, 315 + 210) = (1452.5, 525) -->
        <!-- Display: 111x62mm = 333x186px, centred at (800, 420) -->
        <!-- Display origin: (800-166.5, 420-93) = (633.5, 327) -->

        <!-- Layout plan:
             Scale: 3px per 1mm
             Case: x=148, y=315, w=1305, h=210
             Centre: (800, 420)
             Display: x=634, y=327, w=333, h=186 (centred)
             Left buttons: x=594, 4 circles r=12, spacing 42px, centred vertically
             Right buttons: x=997, mirror of left
             Left available zone: x=158 to x=560, y=325 to y=515
             Right available zone: x=1040 to x=1443, y=325 to y=515
             Dimension arrows: outside case outline
        -->

