	(text "GPIO PIN ALLOCATION:\nSPI0 CS  = GPIO 8  (Pin 24)\nSPI0 MOSI = GPIO 10 (Pin 19)\nSPI0 SCLK = GPIO 11 (Pin 23)\n3.3V = Pin 1/17, GND = Pin 6"
		(exclude_from_sim no)
		(at 25 160 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "9581164b-151f-4eca-9be9-7857f68e91ba")
	)
	(text "CALCULATIONS:\nR_series = V_max / I_fsd = 3.3V / 200uA = 16.5k\nR1 (15k) + RV1 (0-5k) = 15k-20k range\nTrim RV1/RV2 for 0 VU calibration"
		(exclude_from_sim no)
		(at 25 185 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "430881bd-3c5f-439a-ba79-4d7b16af8077")
	)
	(text "POWER BUDGET:\n3.3V: MCP4922 (0.5mA) + VU L (0.2mA) + VU R (0.2mA) = 0.9mA\nWell within Pi 3.3V rail capacity"
		(exclude_from_sim no)
		(at 150 160 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "dc1e8287-1605-4e84-9a6c-5c7b402f6863")
	)
